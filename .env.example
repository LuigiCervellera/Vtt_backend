# Variabili d'Ambiente - Configurazione VTT Backend
# Copia questo file in .env e configura le variabili

# CORS Configuration
# Lista di origini consentite separate da virgola
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Server Info
BASE_URL=http://127.0.0.1:5000

# Security & JWT
# OBBLIGATORIO: genera un secret sicuro con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE-ME-generate-a-secure-secret

# Database Configuration
# PostgreSQL is the mandatory database for both development and production.
# I parametri POSTGRES_* sono usati da Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vtt_db

# String standard: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vtt_db

# Cookie Configuration
# COOKIE_SECURE=True richiede HTTPS — impostare True in produzione
COOKIE_SECURE=False
# COOKIE_SAMESITE: "Lax" per same-domain, "None" per cross-domain (richiede COOKIE_SECURE=True)
COOKIE_SAMESITE=Lax

