# Variabili d'Ambiente - Configurazione VTT Backend
# Copia questo file in .env e configura le variabili

# CORS Configuration
# Lista di origini consentite separate da virgola
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Server Info
BASE_URL=http://127.0.0.1:5000

# Security & JWT (Cambia in produzione!)
JWT_SECRET=dev-only-insecure-secret-change-me

# Database Configuration
# Per PostgreSQL: postgres://user:password@host:port/dbname
# Per SQLite: sqlite://db.sqlite3
DATABASE_URL=sqlite:///home/luigi/Scrivania/gdr/Vtt_backend/db.sqlite3


